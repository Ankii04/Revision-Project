// ============================================================
// DSA Revision Platform — Prisma Schema
// Database: MongoDB
// Version: 1.1 (Converted from PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Difficulty {
  EASY
  MEDIUM
  HARD
  UNKNOWN
}

enum Platform {
  LEETCODE
  GFG
  CODEFORCES
  MANUAL
}

enum Language {
  PYTHON
  JAVA
  CPP
  JAVASCRIPT
  TYPESCRIPT
  GO
  RUST
  KOTLIN
  SWIFT
  CSHARP
}

enum AiNotesStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ImportJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum RecallRating {
  AGAIN
  HARD
  GOOD
  EASY
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @map("_id") // matches Clerk's userId (Plain String)
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  problems       Problem[]
  revisionCards  RevisionCard[]
  revisionLogs   RevisionLog[]
  importJobs     ImportJob[]
  dailyStats     DailyStats[]
  streakRecord   StreakRecord?
  quizSessions   QuizSession[]
  quizProgress   QuizProgress?
  quizRequeues   QuizRequeue[]

  @@map("users")
}


model Problem {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  userId          String     // Clerk ID (Plain String)

  title           String
  slug            String
  platform        Platform   @default(LEETCODE)
  platformId      String?
  platformUrl     String?

  difficulty      Difficulty @default(UNKNOWN)
  tags            String[]   @default([])
  companies       String[]   @default([])
  isPremium       Boolean    @default(false)

  solutionCode    String
  language        Language
  submittedAt     DateTime?

  importedVia     String     @default("manual")
  importJobId     String?    @db.ObjectId

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  importJob       ImportJob?     @relation(fields: [importJobId], references: [id])
  aiNotes         AiNotes?
  revisionCard    RevisionCard?
  revisionLogs    RevisionLog[]
  quizSessionItems QuizSessionItem[]
  quizRequeues    QuizRequeue[]


  @@unique([userId, platform, platformId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, difficulty])
  @@index([userId, platform])
  @@map("problems")
}

model AiNotes {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  problemId String       @unique @db.ObjectId

  status    AiNotesStatus @default(PENDING)
  content   Json?

  promptUsed    String?
  modelVersion  String?   @default("claude-sonnet-4-20250514")

  regenerateCount Int     @default(0)
  lastRegeneratedAt DateTime?

  errorMessage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ai_notes")
}

model RevisionCard {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String // Clerk ID (Plain String)
  problemId String @unique @db.ObjectId

  easeFactor    Float    @default(2.5)
  interval      Int      @default(1)
  repetition    Int      @default(0)
  dueDate       DateTime @default(now())
  lastReviewedAt DateTime?

  totalReviews  Int  @default(0)
  againCount    Int  @default(0)
  hardCount     Int  @default(0)
  goodCount     Int  @default(0)
  easyCount     Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@map("revision_cards")
}

model RevisionLog {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       // Clerk ID (Plain String)
  problemId    String       @db.ObjectId

  rating       RecallRating
  easeFactorBefore Float
  intervalBefore   Int
  easeFactorAfter  Float
  intervalAfter    Int
  nextDueDate      DateTime

  reviewedAt   DateTime     @default(now())

  // Relations
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem      Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt(sort: Desc)])
  @@index([userId, problemId])
  @@map("revision_logs")
}

model ImportJob {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          // Clerk ID (Plain String)

  platform  Platform
  status    ImportJobStatus @default(QUEUED)

  encryptedCookie  String?

  totalFound   Int @default(0)
  totalImported Int @default(0)
  totalSkipped  Int @default(0)
  totalFailed   Int @default(0)

  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems     Problem[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("import_jobs")
}

model DailyStats {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   // Clerk ID (Plain String)
  date       DateTime

  problemsSolved   Int @default(0)
  problemsRevised  Int @default(0)
  againCount       Int @default(0)
  hardCount        Int @default(0)
  goodCount        Int @default(0)
  easyCount        Int @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("daily_stats")
}

model StreakRecord {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique // Clerk ID (Plain String)

  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActiveDate  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streak_records")
}

// ============================================================
// QUIZ SYSTEM MODELS (Spaced Repetition Quiz with Daily Quota)
// ============================================================

/**
 * Represents one day's quiz session for a user.
 * Tracks the quota, items chosen, correctness, and session outcome.
 */
model QuizSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   // Clerk ID

  date        DateTime // Normalized to midnight (one session per day)
  quota       Int      // How many questions this session has

  correctCount Int     @default(0)
  wrongCount   Int     @default(0)

  completed    Boolean  @default(false)
  passed       Boolean  @default(false) // 70%+ correct = pass
  completedAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        QuizSessionItem[]

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("quiz_sessions")
}

/**
 * One question (problem) in a quiz session, with answer tracking.
 */
model QuizSessionItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId   String   @db.ObjectId
  problemId   String   @db.ObjectId

  order       Int      // Position in today's shuffled queue
  answered    Boolean  @default(false)
  correct     Boolean? // null until answered
  answeredAt  DateTime?

  // Relations
  session     QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem     Problem     @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([sessionId, order])
  @@map("quiz_session_items")
}

/**
 * Persists the user's adaptive quota across days.
 * Updated at end of each session to reflect the new quota for tomorrow.
 */
model QuizProgress {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String   @unique // Clerk ID

  currentQuota           Int      @default(5)  // Starts at 5, grows on pass
  totalSessionsCompleted Int      @default(0)
  totalPassedSessions    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_progress")
}

/**
 * Tracks problems that were answered incorrectly and need to be
 * re-shown sooner in the next session (wrong-answer re-queue).
 */
model QuizRequeue {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   // Clerk ID
  problemId    String   @db.ObjectId

  requeueCount Int      @default(1) // How many times this was wrong
  requeuedAt   DateTime @default(now())

  // Relations
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem      Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId, requeuedAt])
  @@map("quiz_requeues")
}
